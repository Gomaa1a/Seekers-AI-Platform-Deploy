# ============================================
# Seekers AI - SaaS Platform Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
APP_NAME=Seekers AI Platform

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/seekers_saas
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# ============================================
# Meta/Facebook App Configuration
# ============================================
# Get these from https://developers.facebook.com/apps/
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Optional: "Instagram app secret" from App Dashboard -> Instagram API setup.
# Needed when Instagram webhooks are configured under the Instagram use case
# (they are signed with this secret, not META_APP_SECRET).
INSTAGRAM_APP_SECRET=
META_REDIRECT_URI=http://localhost:3001/api/meta/oauth/callback
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_here_min_32_chars
META_API_VERSION=v23.0

# Required Meta Scopes (for reference - defined in src/config/environment.ts)
# pages_show_list,pages_read_engagement,pages_manage_metadata,pages_manage_engagement,
# pages_messaging,pages_read_user_content,instagram_basic,instagram_manage_messages,
# instagram_manage_comments,public_profile

# ============================================
# JWT Configuration
# ============================================
# Generate with: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_long_for_security
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_different_from_main
JWT_REFRESH_EXPIRES_IN=30d

# Admin JWT (separate for extra security)
ADMIN_JWT_SECRET=your_admin_jwt_secret_completely_different
ADMIN_JWT_EXPIRES_IN=8h

# ============================================
# Encryption (for storing Meta access tokens)
# ============================================
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here_generated_by_openssl

# ============================================
# n8n Configuration
# ============================================
N8N_DEFAULT_SERVER_URL=https://n8n.seekersai.org
N8N_API_KEY=your_n8n_api_key_if_needed
N8N_WEBHOOK_BASE_URL=https://n8n.seekersai.org/webhook
N8N_WEBHOOK_TIMEOUT=30000

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Seekers AI <noreply@seekersai.org>

# ============================================
# File Upload Configuration
# ============================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain
UPLOAD_PATH=./uploads

# ============================================
# Monitoring & Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_DIR=./logs
SENTRY_DSN=

# ============================================
# Security Configuration
# ============================================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ADMIN_MAX=500
BCRYPT_ROUNDS=12

# ============================================
# Session Configuration
# ============================================
SESSION_SECRET=your_session_secret_for_oauth_state
SESSION_MAX_AGE=86400000

# ============================================
# WebSocket Configuration
# ============================================
WS_ENABLED=true
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=5000

# ============================================
# Seekers AI Branding
# ============================================
COMPANY_NAME=Seekers AI
PRODUCT_NAME=Seekers AI Platform
SUPPORT_EMAIL=support@seekersai.org
CONTACT_PHONE=01044332566
WEBSITE_URL=https://www.seekersai.org

# ===== AI =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AGENT_BUFFER_SECONDS=6
